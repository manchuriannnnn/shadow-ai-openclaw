# ============================================================
# Shadow AI — OpenClaw Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# OpenAI / LLM
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...
# Optional: use a different model (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# ------------------------------------------------------------
# Google / Gmail / Calendar
# ------------------------------------------------------------
# OAuth2 credentials from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Your Gmail address (used as sender/filter)
GMAIL_USER=your@gmail.com

# ------------------------------------------------------------
# Google Drive
# ------------------------------------------------------------
# Service account JSON key path (for Drive file access)
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/service-account.json
# Folder ID where PRD and project files are stored
DRIVE_ROOT_FOLDER_ID=

# ------------------------------------------------------------
# Meeting / Recall.ai (bot that joins calls)
# ------------------------------------------------------------
RECALL_API_KEY=
# Comma-separated list of calendar event IDs or meeting URLs to auto-join
# Leave empty to auto-join all calendar events
AUTO_JOIN_MEETINGS=true

# ------------------------------------------------------------
# Vector Store / RAG (ChromaDB)
# ------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8000
# Collection name for the Magic Bus PRD embeddings
CHROMA_COLLECTION=magic-bus-prd

# ------------------------------------------------------------
# Notion (task manager sync — optional)
# ------------------------------------------------------------
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ------------------------------------------------------------
# Slack (notifications — optional)
# ------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=

# ------------------------------------------------------------
# Approval Webhook
# Used by email-agent to send draft emails for your approval
# Can be a local ngrok URL during dev, or your prod domain
# ------------------------------------------------------------
APPROVAL_WEBHOOK_URL=http://localhost:4000/approve

# ------------------------------------------------------------
# App / Server
# ------------------------------------------------------------
PORT=18789
NODE_ENV=development
LOG_LEVEL=info
# Secret used to sign approval tokens
JWT_SECRET=change-me-to-a-random-secret
